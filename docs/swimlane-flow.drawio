        </mxCell>
        <!-- ── PARALLEL LABEL ── -->
        <mxCell id="r-parallel-label" value="asyncio.gather() — all 3 providers run simultaneously" style="text;html=1;align=center;strokeColor=#9673a6;fillColor=#e1d5e7;fontSize=11;fontStyle=3;rounded=1;" vertex="1" parent="rpool">
          <mxGeometry x="570" y="344" width="560" height="30" as="geometry" />
        </mxCell>
        <!-- ── STEP SHAPES ── -->
        <!-- START -->
        <mxCell id="r-start" value="Start" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="rlu">
