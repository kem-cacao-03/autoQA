        <!-- ── PARALLEL CALLS (y=460) ── -->
        <!-- GPT-4o -->
        <mxCell id="r-oai-call" value="call(&#39;openai&#39;,&#xa;build_research_prompt(),&#xa;SYSTEM_RESEARCH)&#xa;→ test suite JSON" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="rloai">
