        <mxCell id="r-submit-fe" value="POST /generate&#xa;{ requirement,&#xa;  mode: research,&#xa;  providers: [...] }" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="rlf">
